# TheStaff runtime config — copy to .env (gitignored) and fill in:  cp .env.example .env
# Loaded automatically by scripts/run.sh, start.sh and update.sh.
#
# Operator token — REQUIRED by start.sh / update.sh / run.sh. It gates all
# mutating / active endpoints (scan, accept, healthcheck, wipe, AI). Put the SAME
# value in the dashboard: ⚙ Settings → Operator token.
#
# Generate a random token (pick one):
#   openssl rand -hex 24
#   python3 -c "import secrets; print(secrets.token_hex(24))"
#   head -c24 /dev/urandom | od -An -tx1 | tr -d ' \n'; echo
#
# …or generate it straight into this var (after `cp .env.example .env`):
#   sed -i "s|^THESTAFF_ADMIN_TOKEN=.*|THESTAFF_ADMIN_TOKEN=$(openssl rand -hex 24)|" .env
THESTAFF_ADMIN_TOKEN=

# Optional — any other THESTAFF_* var or TARGET_CIDR / SCAN_INTERVAL_MIN can live
# here too; see backend/.env.example for the full list and defaults.
# TARGET_CIDR=192.168.50.0/24
# SCAN_INTERVAL_MIN=15
