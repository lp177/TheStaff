# ---- thestaff runtime data ----
# The whole data dir is runtime-generated and may contain REAL device data
# (scan DB + nmap XML with IPs/MACs) and the large offline NVD feed. The app
# recreates it on start (ensure_dirs / scripts mkdir -p), so never commit it.
/data/
*.log

