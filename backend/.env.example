# thestaff configuration (copy to .env or pass as -e to podman)

# "mock" = synthetic LAN for demos/dev (no network/nmap needed).
# "real" = scan TARGET_CIDR with nmap.
THESTAFF_MODE=mock

# Network to scan. "auto" detects the LAN subnet from the host's interfaces
# (excludes docker/bridge/wireguard/VPN). Set an explicit CIDR to override,
# e.g. TARGET_CIDR=192.168.50.0/24
TARGET_CIDR=auto
SCAN_INTERVAL_MIN=15

# Ports scanned in Stage 2 (covers the device classes we fingerprint).
# THESTAFF_PORTS=22,53,80,139,443,445,515,554,631,1900,5000,5353,7000,8008,8009,8060,8443,9100,32400,49152,62078

# NSE scripts for CVE detection. Empty disables script scanning.
# THESTAFF_NSE=vulners,vulscan/vulscan.nse

# Run a scan immediately on startup.
THESTAFF_SCAN_ON_START=1

# Opportunistic online CVE enrichment (off by default for flaky venue wifi).
THESTAFF_ONLINE_ENRICH=0

# Show the network's public/WAN IP on the central "Event network" node. A public
# IP bound directly to an interface is always detected offline; otherwise a single
# cached request to an external echo service finds the NAT address (the only call
# thestaff makes outside the LAN). Set to 0 for fully-offline/closed events
# (the node then shows "Private closed network"). Never runs in mock mode.
THESTAFF_PUBLIC_IP_LOOKUP=1

# "Ask AI about this CVE" operator helper. The browser holds the Claude/OpenAI API
# key (localStorage) and sends it per request; the backend proxies to the provider
# (required because OpenAI blocks browser CORS) and never stores the key. This adds
# outbound calls to api.anthropic.com / api.openai.com only when an operator uses it.
# Set to 0 to disable the proxy entirely for fully-offline events.
THESTAFF_AI_PROXY=1

# Consent model:
#   wifi = possessing the WiFi password = consent (out-of-band via signage/briefing);
#          headless/IoT devices are enrolled by connecting — no web page needed.
#   http = per-device explicit opt-in via the consent page checkbox.
THESTAFF_CONSENT_MODE=wifi

# Branding shown on the consent page.
THESTAFF_ORGANIZER=the event team
THESTAFF_ORGANIZER_EMAIL=security@example.org
THESTAFF_SSID=thestaff-challenge
THESTAFF_EVENT=our hack event

# Paths (defaults are fine inside the container).
# THESTAFF_DATA_DIR=data
# THESTAFF_NVD_DIR=data/nvd
